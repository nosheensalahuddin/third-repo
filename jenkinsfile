pipeline {
    agent any

    stages {

        stage('Git Check') {
            steps {
                bat '"C:\\Program Files\\Git\\cmd\\git.exe" --version'
            }
        }

        stage('Java Check') {
            steps {
                bat 'java -version'
            }
        }

        stage('Workspace') {
            steps {
                bat 'dir'
            }
        }
    }

    post {
        success {
            echo 'Pipeline Successful'
        }

        failure {
            echo 'Pipeline Failed'
        }
    }
}
